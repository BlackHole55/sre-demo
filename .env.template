# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=boutique
POSTGRES_PASSWORD=boutique
POSTGRES_DB=boutique

# ── Service DSNs (auto-built from above, or override here) ───────
# Format: postgres://USER:PASSWORD@HOST:PORT/DB?sslmode=disable&search_path=SCHEMA
PRODUCTCATALOG_POSTGRES_DSN=
CHECKOUT_POSTGRES_DSN=
AUTH_POSTGRES_DSN=

# ── Service Endpoints ─────────────────────────────────────────────
# Format: hostname:port (must use Docker service names, not localhost)
PRODUCT_CATALOG_SERVICE_ADDR=productcatalogservice:3550
CHECKOUT_SERVICE_ADDR=checkoutservice:5050
CART_SERVICE_ADDR=cartservice:7070
AUTH_SERVICE_ADDR=authservice:9555

# ── Optional services (leave empty to disable) ───────────────────
CURRENCY_SERVICE_ADDR=
RECOMMENDATION_SERVICE_ADDR=
SHIPPING_SERVICE_ADDR=
EMAIL_SERVICE_ADDR=
PAYMENT_SERVICE_ADDR=

# ── Frontend ─────────────────────────────────────────────────────
PORT=8080
ENABLE_PROFILER=0
ENV_PLATFORM=local

# ── Monitoring ───────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── Redis ─────────────────────────────────────────────────────────
REDIS_ADDR=redis:6379
