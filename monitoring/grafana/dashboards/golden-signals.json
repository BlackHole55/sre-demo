        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "go_memstats_alloc_bytes{job=\"frontend\"}",
          "legendFormat": "frontend heap",
          "refId": "A"
        },
        {
          "expr": "go_memstats_alloc_bytes{job=\"productcatalogservice\"}",
          "legendFormat": "productcatalog heap",
          "refId": "B"
        },
        {
          "expr": "go_memstats_alloc_bytes{job=\"checkoutservice\"}",
          "legendFormat": "checkout heap",
          "refId": "C"
        },
        {
          "expr": "go_memstats_alloc_bytes{job=\"authservice\"}",
          "legendFormat": "auth heap",
          "refId": "D"
        },
        {
          "expr": "redis_memory_used_bytes{job=\"redis\"}",
          "legendFormat": "redis memory",
          "refId": "E"
        }
      ],
      "title": "Memory Usage by Service",
      "type": "timeseries"
