      "id": 8,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "go_goroutines{job=\"frontend\"}",
          "legendFormat": "frontend goroutines",
          "refId": "A"
        },
        {
          "expr": "go_goroutines{job=\"productcatalogservice\"}",
          "legendFormat": "productcatalog goroutines",
          "refId": "B"
        },
        {
          "expr": "go_goroutines{job=\"checkoutservice\"}",
          "legendFormat": "checkout goroutines",
          "refId": "C"
        },
        {
          "expr": "http_active_requests{job=\"frontend\"}",
