{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Four Golden Signals — Latency, Traffic, Errors, Saturation + SLI/SLO Status",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 200,
      "title": "SLO Status — Service Level Objectives",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "SLO: Availability ≥ 99% — percentage of time frontend is up and serving requests",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null  },
              { "color": "yellow", "value": 0.95  },
              { "color": "green",  "value": 0.99  }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 201,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "1 - (sum(rate(http_requests_total{job=\"frontend\", status=~\"Internal Server Error|Bad Gateway|Service Unavailable\"}[1h])) / sum(rate(http_requests_total{job=\"frontend\"}[1h])))",
          "legendFormat": "Availability (1h)",
          "refId": "A"
        }
      ],
      "title": "SLI: Availability",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "SLO: p95 latency ≤ 200ms — 95th percentile response time over last 5 minutes",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null  },
              { "color": "yellow", "value": 0.15  },
              { "color": "red",    "value": 0.20  }
            ]
          },
          "unit": "s",
          "min": 0,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 202,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"frontend\"}[5m])) by (le))",
          "legendFormat": "p95 Latency",
          "refId": "A"
        }
      ],
      "title": "SLI: Latency (p95)",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "SLO: Error rate ≤ 1% — percentage of requests returning errors over last 5 minutes",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null  },
              { "color": "yellow", "value": 0.005 },
              { "color": "red",    "value": 0.01  }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 203,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"frontend\", status=~\"Internal Server Error|Bad Gateway|Service Unavailable\"}[5m])) / sum(rate(http_requests_total{job=\"frontend\"}[5m]))",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ],
      "title": "SLI: Error Rate",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "SLO: Request success rate ≥ 99% — percentage of requests that completed successfully",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null  },
              { "color": "yellow", "value": 0.95  },
              { "color": "green",  "value": 0.99  }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 204,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"frontend\", status!~\"Internal Server Error|Bad Gateway|Service Unavailable\"}[5m])) / sum(rate(http_requests_total{job=\"frontend\"}[5m]))",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ],
      "title": "SLI: Request Success Rate",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "SLO burn rate — how fast error budget is being consumed. >1 = burning faster than allowed",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1    },
              { "color": "red",    "value": 5    }
            ]
          },
          "unit": "short",
          "mappings": [
            { "options": { "match": "null" }, "result": { "text": "N/A" }, "type": "special" }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 7 },
      "id": 205,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"frontend\", status=~\"Internal Server Error|Bad Gateway|Service Unavailable\"}[1h])) / sum(rate(http_requests_total{job=\"frontend\"}[1h])) / 0.01",
          "legendFormat": "Frontend burn rate (1h)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(grpc_requests_total{job=\"checkoutservice\", status!=\"OK\"}[1h])) / sum(rate(grpc_requests_total{job=\"checkoutservice\"}[1h])) / 0.01",
          "legendFormat": "Checkout burn rate (1h)",
          "refId": "B"
        }
      ],
      "title": "Error Budget Burn Rate (1h) — SLO: 1% error budget",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Rolling 24h SLO compliance — green = meeting SLO, red = breaching",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "SLO Target (99%)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          }
        ]
      },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 7 },
      "id": 206,
      "options": {
        "legend": { "calcs": ["mean", "min"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "1 - (sum(rate(http_requests_total{job=\"frontend\", status=~\"Internal Server Error|Bad Gateway|Service Unavailable\"}[1h])) / sum(rate(http_requests_total{job=\"frontend\"}[1h])))",
          "legendFormat": "Availability (rolling 1h)",
          "refId": "A"
        },
        {
          "expr": "vector(0.99)",
          "legendFormat": "SLO Target (99%)",
          "refId": "B"
        }
      ],
      "title": "Availability vs SLO Target (99%)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "id": 100,
      "title": "TRAFFIC — Requests per second",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"frontend\"}[1m]))",
          "legendFormat": "frontend",
          "refId": "A"
        },
        {
          "expr": "sum(rate(grpc_requests_total{job=\"productcatalogservice\"}[1m]))",
          "legendFormat": "productcatalog",
          "refId": "B"
        },
        {
          "expr": "sum(rate(grpc_requests_total{job=\"checkoutservice\"}[1m]))",
          "legendFormat": "checkout",
          "refId": "C"
        },
        {
          "expr": "sum(rate(grpc_requests_total{job=\"authservice\"}[1m]))",
          "legendFormat": "auth",
          "refId": "D"
        }
      ],
      "title": "Request Rate by Service",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 101,
      "title": "LATENCY — Request duration",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "SLO Threshold (200ms)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"frontend\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"frontend\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"frontend\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        },
        {
          "expr": "vector(0.20)",
          "legendFormat": "SLO Threshold (200ms)",
          "refId": "D"
        }
      ],
      "title": "Frontend Latency vs SLO (200ms)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "id": 102,
      "title": "ERRORS — Error rates",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "unit": "percentunit"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "SLO Threshold (1%)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"frontend\", status=~\"Internal Server Error|Bad Gateway|Service Unavailable\"}[5m])) / sum(rate(http_requests_total{job=\"frontend\"}[5m]))",
          "legendFormat": "frontend error %",
          "refId": "A"
        },
        {
          "expr": "sum(rate(grpc_requests_total{job=\"checkoutservice\", status!=\"OK\"}[5m])) / sum(rate(grpc_requests_total{job=\"checkoutservice\"}[5m]))",
          "legendFormat": "checkout error %",
          "refId": "B"
        },
        {
          "expr": "sum(rate(grpc_requests_total{job=\"productcatalogservice\", status!=\"OK\"}[5m])) / sum(rate(grpc_requests_total{job=\"productcatalogservice\"}[5m]))",
          "legendFormat": "productcatalog error %",
          "refId": "C"
        },
        {
          "expr": "sum(rate(grpc_requests_total{job=\"authservice\", status!=\"OK\"}[5m])) / sum(rate(grpc_requests_total{job=\"authservice\"}[5m]))",
          "legendFormat": "auth error %",
          "refId": "D"
        },
        {
          "expr": "vector(0.01)",
          "legendFormat": "SLO Threshold (1%)",
          "refId": "E"
        }
      ],
      "title": "Error Rate vs SLO (1%)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null  },
              { "color": "yellow", "value": 0.005 },
              { "color": "red",    "value": 0.01  }
            ]
          },
          "unit": "percentunit",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "id": 6,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"frontend\", status=~\"Internal Server Error|Bad Gateway|Service Unavailable\"}[5m])) / sum(rate(http_requests_total{job=\"frontend\"}[5m]))",
          "legendFormat": "Frontend",
          "refId": "A"
        },
        {
          "expr": "sum(rate(grpc_requests_total{job=\"checkoutservice\", status!=\"OK\"}[5m])) / sum(rate(grpc_requests_total{job=\"checkoutservice\"}[5m]))",
          "legendFormat": "Checkout",
          "refId": "B"
        },
        {
          "expr": "sum(rate(grpc_requests_total{job=\"authservice\", status!=\"OK\"}[5m])) / sum(rate(grpc_requests_total{job=\"authservice\"}[5m]))",
          "legendFormat": "Auth",
          "refId": "C"
        }
      ],
      "title": "Current Error Rate (green < 0.5%, red > 1%)",
